# STRICT: Prevent ALL platform-specific optional dependencies
optional=false
omit=optional

# Force Linux platform & binary resolution
platform=linux
arch=x64
libc=glibc
os=linux

# Prevent scripts that build darwin binaries
ignore-scripts=true

# Allow soft engine version warnings (Railway has 20.18.1, need 20.19.0)
engine-strict=false

# Performance
prefer-offline=true
fetch-timeout=60000
