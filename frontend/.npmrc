# Force Linux platform & binary resolution ONLY
platform=linux
arch=x64
libc=glibc
os=linux

# Allow optional dependencies (needed by Vite/Rollup for platform-specific binaries)
# They will install as linux-x64-gnu versions due to platform settings above
optional=true

# Prevent build scripts from compiling darwin binaries
ignore-scripts=true

# Allow soft engine version warnings
engine-strict=false

# Performance
prefer-offline=true
fetch-timeout=60000
